# LuxPretty — Environment template
#
# Copy this file to .env and fill in real values. Never commit .env (already in .gitignore).
#
# Usage:
#   cp .env.example .env
#   # then edit .env
#
# All values below are required for `docker compose --profile dev up` and
# for running the backend with `mvn spring-boot:run`.

# Oracle SYSTEM password (admin account, used by docker-compose to bootstrap the DB)
ORACLE_PASSWORD=

# Oracle admin account used by TenantSchemaManager to CREATE USER for new
# tenants (CREATE USER needs DBA privileges that APP_USER does not have).
# With gvenzl/oracle-free this is SYSTEM, authenticated by ORACLE_PASSWORD.
ORACLE_ADMIN_USER=SYSTEM

# Application schema user — owns the shared tables (USERS, TENANTS, ...)
APP_USER=appuser
APP_USER_PASSWORD=

# JWT signing secret (>= 32 bytes for HS256). The app fails to start if missing.
JWT_SECRET=

# OAuth2 redirect URI after successful Google login (Angular frontend route).
OAUTH2_REDIRECT_URI=http://localhost:4300/oauth2/redirect

# CORS allowed origins (comma-separated). Local dev: Angular dev server + Docker frontend.
CORS_ALLOWED_ORIGINS=http://localhost:4300,http://localhost:4200

# Frontend base URL — used in outgoing emails (password reset links, etc.).
FRONTEND_BASE_URL=http://localhost:4300

# Storage backend selection. "local" (default) writes to ./uploads and is
# suitable for dev and tests. "r2" writes to Cloudflare R2 (prod).
# When set to "r2", the four R2_* values below MUST be filled in.
STORAGE_BACKEND=local

# Cloudflare R2 credentials (only required when STORAGE_BACKEND=r2).
# Find Account ID at: dash.cloudflare.com → right sidebar → API → Account ID.
# Create API tokens at: dash.cloudflare.com → R2 → Manage R2 API Tokens
# (token must have Object Read & Write on the bucket).
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
